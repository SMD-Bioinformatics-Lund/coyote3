# Core secrets (set real values per environment)
SECRET_KEY='CHANGE_ME'
COYOTE3_FERNET_KEY='CHANGE_ME'
INTERNAL_API_TOKEN='CHANGE_ME'
API_SESSION_SALT='CHANGE_ME'

# Runtime identity
COYOTE3_DB='coyote3'
SESSION_COOKIE_NAME='coyote3'
API_SESSION_COOKIE_NAME='coyote3_api_session'
SCRIPT_NAME='/coyote3'

# MongoDB
# Required: set full URI (appends COYOTE3_DB if no db path is present)
MONGO_URI='mongodb://coyote3_mongo:27017/coyote3'
COYOTE3_MONGO_PORT='5818'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3:6379/0'

# Host port mappings (compose)
COYOTE3_WEB_PORT='5814'
COYOTE3_API_PORT='5816'
COYOTE3_REDIS_PORT='5817'
COYOTE3_DEV_WEB_PORT='6817'
COYOTE3_DEV_API_PORT='6816'
COYOTE3_DEV_REDIS_PORT='5819'
COYOTE3_DEV_MONGO_PORT='37017'

# Build metadata (optional)
COYOTE3_VERSION='local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'

# App behavior
FLASK_DEBUG='0'
DEVELOPMENT='0'
TESTING='0'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/reports'

# Optional integrations
GENS_URI=''
IGV_URI=''
LOCAL_AUTH_USER_IDENTIFIERS=''
