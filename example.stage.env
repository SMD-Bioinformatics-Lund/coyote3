# Core secrets (set real values per environment)
SECRET_KEY='CHANGE_ME_STAGE'
COYOTE3_FERNET_KEY='CHANGE_ME_STAGE'
INTERNAL_API_TOKEN='CHANGE_ME_STAGE'
API_SESSION_SALT='CHANGE_ME_STAGE'

# Runtime identity
ENV_NAME='staging'
COYOTE3_DB='coyote3_stage'
SESSION_COOKIE_NAME='coyote3_stage'
API_SESSION_COOKIE_NAME='coyote3_stage_api_session'
SCRIPT_NAME='/coyote3'

# MongoDB
# Required: use staging Mongo URI and staging DB
MONGO_URI='mongodb://coyote3_mongo:27017/coyote3_stage'
COYOTE3_MONGO_PORT='7818'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3:6379/0'

# Host port mappings (compose)
COYOTE3_WEB_PORT='7814'
COYOTE3_API_PORT='7816'
COYOTE3_REDIS_PORT='7817'

# Build metadata (optional)
COYOTE3_VERSION='staging-local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'

# App behavior
FLASK_DEBUG='0'
DEVELOPMENT='0'
TESTING='0'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/staging/reports'

# Optional integrations
GENS_URI=''
IGV_URI=''
LOCAL_AUTH_USER_IDENTIFIERS=''
