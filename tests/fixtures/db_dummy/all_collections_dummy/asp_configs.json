[
  {
    "aspc_id": "assay_1:production",
    "assay_name": "assay_1",
    "display_name": "Hema GMS v1",
    "asp_group": "hematology",
    "asp_category": "dna",
    "description": "Demo ASP config for first-run DNA sample workflows",
    "reference_genome": "GRCh38",
    "platform": "Illumina",
    "environment": "production",
    "version": 1,
    "is_active": true,
    "analysis_types": [
      "SNV",
      "CNV"
    ],
    "filters": {
      "max_freq": 1.0,
      "min_freq": 0.03,
      "max_control_freq": 0.05,
      "max_popfreq": 0.01,
      "min_depth": 100,
      "min_alt_reads": 5,
      "min_cnv_size": 100,
      "max_cnv_size": 1000000,
      "cnv_loss_cutoff": -0.3,
      "cnv_gain_cutoff": 0.3,
      "warn_cov": 500,
      "error_cov": 100,
      "vep_consequences": [
        "splicing",
        "stop_gained",
        "stop_lost",
        "start_lost",
        "frameshift",
        "inframe_indel",
        "missense",
        "other_coding"
      ],
      "cnveffects": [
        "gain",
        "loss"
      ],
      "genelists": []
    },
    "query": {
      "snv": {
        "$or": [
          {
            "INFO.MYELOID_GERMLINE": 1
          },
          {
            "FILTER": {
              "$in": [
                "GERMLINE"
              ]
            },
            "INFO.CSQ": {
              "$elemMatch": {
                "SYMBOL": "CEBPA"
              }
            }
          },
          {
            "$and": [
              {
                "POS": {
                  "$gt": 115256520
                }
              },
              {
                "POS": {
                  "$lt": 115256538
                }
              },
              {
                "CHROM": 1
              }
            ]
          },
          {
            "$and": [
              {
                "genes": {
                  "$in": [
                    "FLT3"
                  ]
                }
              },
              {
                "$or": [
                  {
                    "INFO.SVTYPE": {
                      "$exists": "true"
                    }
                  },
                  {
                    "ALT": {
                      "$regex": "\\w{10,200}",
                      "$options": "i"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    "reporting": {
      "report_sections": [
        "SNV",
        "CNV"
      ],
      "report_header": "Demo report header",
      "report_method": "Demo method",
      "report_description": "DNA panel summary report for assay_1",
      "general_report_summary": "Automated summary generated from curated panel filters.",
      "plots_path": "/tmp",
      "report_folder": "demo"
    },
    "verification_samples": {}
  },
