# Staging environment template.
# Copy to .coyote3_stage_env and replace all CHANGE_ME values.

# Core app secrets
SECRET_KEY='CHANGE_ME_STAGE_SECRET_KEY'
COYOTE3_FERNET_KEY='CHANGE_ME_STAGE_FERNET_KEY'
INTERNAL_API_TOKEN='CHANGE_ME_STAGE_INTERNAL_TOKEN'
API_SESSION_SALT='CHANGE_ME_STAGE_SESSION_SALT'

# Runtime identity
ENV_NAME='staging'
COYOTE3_DB='coyote3'
SESSION_COOKIE_NAME='coyote3_stage'
API_SESSION_COOKIE_NAME='coyote3_stage_api_session'
SCRIPT_NAME='/coyote3'

# MongoDB
MONGO_ROOT_USERNAME='coyote3_root'
MONGO_ROOT_PASSWORD='CHANGE_ME_STAGE_ROOT_PASSWORD'
MONGO_APP_USER='coyote3_app'
MONGO_APP_PASSWORD='CHANGE_ME_STAGE_APP_PASSWORD'
MONGO_URI='mongodb://coyote3_app:CHANGE_ME_STAGE_APP_PASSWORD@coyote3_stage_mongo:27017/coyote3'
COYOTE3_STAGE_MONGO_PORT='47017'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3_stage:6379/0'

# Host port mappings (compose)
COYOTE3_STAGE_WEB_PORT='7814'
COYOTE3_STAGE_API_PORT='7816'
COYOTE3_STAGE_REDIS_PORT='7817'

# Build metadata (optional)
COYOTE3_VERSION='staging-local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'

# App behavior
FLASK_DEBUG='0'
DEVELOPMENT='0'
TESTING='0'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/staging/reports'

# Optional integrations
GENS_URI=''
IGV_URI=''
LOCAL_AUTH_USER_IDENTIFIERS=''
