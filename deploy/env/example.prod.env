# Production environment template.
# Copy to .coyote3_env and replace all CHANGE_ME values.

# Core app secrets
SECRET_KEY='CHANGE_ME_PROD_SECRET_KEY'
INTERNAL_API_TOKEN='CHANGE_ME_PROD_INTERNAL_TOKEN'
API_SESSION_SALT='CHANGE_ME_PROD_SESSION_SALT'
PASSWORD_TOKEN_SALT='CHANGE_ME_PROD_PASSWORD_TOKEN_SALT'

# Runtime identity
ENV_NAME='production'
COYOTE3_DB='coyote3'
SESSION_COOKIE_NAME='coyote3'
API_SESSION_COOKIE_NAME='coyote3_api_session'
SCRIPT_NAME='/coyote3'

# MongoDB (prod must be dedicated and isolated)
MONGO_ROOT_USERNAME='coyote3_root'
MONGO_ROOT_PASSWORD='CHANGE_ME_PROD_ROOT_PASSWORD'
MONGO_APP_USER='coyote3_app'
MONGO_APP_PASSWORD='CHANGE_ME_PROD_APP_PASSWORD'
MONGO_URI='mongodb://coyote3_app:CHANGE_ME_PROD_APP_PASSWORD@coyote3_mongo:27017/coyote3'
COYOTE3_MONGO_PORT='5820'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3:6379/0'
DASHBOARD_SUMMARY_CACHE_TTL_SECONDS='60'
DASHBOARD_SUMMARY_SNAPSHOT_MAX_AGE_SECONDS='300'
DASHBOARD_SUMMARY_SNAPSHOT_TTL_SECONDS='604800'

# Host port mappings (compose)
COYOTE3_WEB_PORT='5816'
COYOTE3_DOCS_PORT='5821'
COYOTE3_API_PORT='5818'
COYOTE3_REDIS_PORT='5819'

# Build metadata (optional)
COYOTE3_VERSION='prod-local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'
API_WORKERS='4'

# App behavior
FLASK_DEBUG='0'
DEVELOPMENT='0'
TESTING='0'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/reports'

# LDAP authentication (required — set to your center's LDAP server)
LDAP_HOST='ldap://CHANGE_ME_LDAP_HOST'
LDAP_BASE_DN='CHANGE_ME_LDAP_BASE_DN'
LDAP_BINDDN='CHANGE_ME_LDAP_BINDDN'
LDAP_SECRET='CHANGE_ME_LDAP_SECRET'

# CORS (required in production — comma-separated list of allowed origins)
CORS_ORIGINS='https://CHANGE_ME_COYOTE3_HOST'

# Center contact information (shown in UI contact page)
CONTACT_CLINICAL_EMAIL='CHANGE_ME_CLINICAL_EMAIL'
CONTACT_RESEARCH_EMAIL='CHANGE_ME_RESEARCH_EMAIL'
CONTACT_SAMPLES_EMAIL='CHANGE_ME_SAMPLES_EMAIL'
CONTACT_PHONE_MAIN='CHANGE_ME_PHONE_MAIN'
CONTACT_PHONE_URGENT='CHANGE_ME_PHONE_URGENT'
CONTACT_ADDRESS='CHANGE_ME_CENTER_ADDRESS'

# Optional integrations
GENS_URI=''
IGV_URI=''

# SMTP mail delivery (org relay mode)
SMTP_HOST='mxis.skane.se'
SMTP_PORT='25'
SMTP_USERNAME=''
SMTP_PASSWORD=''
SMTP_USE_TLS='0'
SMTP_USE_SSL='0'
SMTP_FROM_EMAIL='noreply@coyote3.local'
SMTP_FROM_NAME='Coyote3'
WEB_APP_BASE_URL='https://CHANGE_ME_COYOTE3_HOST/coyote3'
HELP_CENTER_URL='https://CHANGE_ME_COYOTE3_HOST:5821/'
PASSWORD_TOKEN_TTL_SECONDS='3600'
