# Testing environment template.
# Copy to .coyote3_test_env for test-stack and CI-like local runs.

# Core app secrets (test-only placeholders)
SECRET_KEY='ci-test-secret-key'
COYOTE3_FERNET_KEY='MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY='
INTERNAL_API_TOKEN='ci-test-internal-token'
API_SESSION_SALT='ci-test-session-salt'

# Runtime identity
ENV_NAME='test'
COYOTE3_DB='coyote3_test'
SESSION_COOKIE_NAME='coyote3_test'
API_SESSION_COOKIE_NAME='coyote3_test_api_session'
SCRIPT_NAME='/coyote3_test'

# MongoDB (compose-managed test Mongo)
MONGO_ROOT_USERNAME='coyote3_root'
MONGO_ROOT_PASSWORD='CHANGE_ME_TEST_ROOT_PASSWORD'
MONGO_APP_USER='coyote3_app'
MONGO_APP_PASSWORD='CHANGE_ME_TEST_APP_PASSWORD'
MONGO_URI='mongodb://coyote3_app:CHANGE_ME_TEST_APP_PASSWORD@coyote3_test_mongo:27017/coyote3_test'
COYOTE3_TEST_MONGO_PORT='6814'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3_test:6379/0'
DASHBOARD_SUMMARY_CACHE_TTL_SECONDS='15'
DASHBOARD_SUMMARY_SNAPSHOT_MAX_AGE_SECONDS='60'
DASHBOARD_SUMMARY_SNAPSHOT_TTL_SECONDS='86400'

# Host port mappings (compose)
COYOTE3_TEST_WEB_PORT='6811'
COYOTE3_TEST_API_PORT='6812'
COYOTE3_TEST_REDIS_PORT='6813'
COYOTE3_TEST_DOCS_PORT='6815'

# Build metadata (optional)
COYOTE3_VERSION='test-local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'
API_WORKERS='2'

# App behavior
FLASK_DEBUG='0'
DEVELOPMENT='0'
TESTING='1'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/test/reports'

# Optional integrations
GENS_URI=''
IGV_URI=''

# SMTP mail delivery (org relay mode)
SMTP_HOST='mxis.skane.se'
SMTP_PORT='25'
SMTP_USERNAME=''
SMTP_PASSWORD=''
SMTP_USE_TLS='0'
SMTP_USE_SSL='0'
SMTP_FROM_EMAIL='noreply@coyote3.local'
SMTP_FROM_NAME='Coyote3'
WEB_APP_BASE_URL='http://localhost:6811/coyote3_test'
HELP_CENTER_URL='http://localhost:6815/'
PASSWORD_TOKEN_TTL_SECONDS='3600'

# Compose-native first-run bootstrap (profile: first-run)
COYOTE3_FIRST_RUN='0'
FIRST_RUN_ADMIN_EMAIL=''
FIRST_RUN_ADMIN_PASSWORD=''
FIRST_RUN_API_BASE_URL='http://coyote3_test_api:8001'
FIRST_RUN_MONGO_URI=''
FIRST_RUN_DB_NAME=''
FIRST_RUN_SEED_FILE='tests/fixtures/db_dummy/all_collections_dummy'
FIRST_RUN_REFERENCE_SEED_DATA=''
FIRST_RUN_YAML_FILE='tests/data/ingest_demo/generic_case_control.yaml'
FIRST_RUN_ASSAY_GROUP='GROUP_A'
FIRST_RUN_ASSAY='ASSAY_A'
FIRST_RUN_WITH_OPTIONAL='0'
FIRST_RUN_SKIP_EXISTING='1'
FIRST_RUN_RUN_SMOKE='1'
