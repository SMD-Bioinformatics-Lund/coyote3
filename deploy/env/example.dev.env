# Development environment template.
# Copy to .coyote3_dev_env and replace all CHANGE_ME values.

# Core app secrets
SECRET_KEY='CHANGE_ME_DEV_SECRET_KEY'
INTERNAL_API_TOKEN='CHANGE_ME_DEV_INTERNAL_TOKEN'
API_SESSION_SALT='CHANGE_ME_DEV_SESSION_SALT'
PASSWORD_TOKEN_SALT='CHANGE_ME_DEV_PASSWORD_TOKEN_SALT'

# Runtime identity
ENV_NAME='development'
COYOTE3_DB='coyote3'
SESSION_COOKIE_NAME='coyote3_dev'
API_SESSION_COOKIE_NAME='coyote3_dev_api_session'
SCRIPT_NAME='/coyote3_dev'

# MongoDB (compose-managed dev Mongo)
MONGO_ROOT_USERNAME='coyote3_root'
MONGO_ROOT_PASSWORD='CHANGE_ME_DEV_ROOT_PASSWORD'
MONGO_APP_USER='coyote3_app'
MONGO_APP_PASSWORD='CHANGE_ME_DEV_APP_PASSWORD'
MONGO_URI='mongodb://coyote3_app:CHANGE_ME_DEV_APP_PASSWORD@coyote3_dev_mongo:27017/coyote3'
COYOTE3_DEV_MONGO_PORT='6804'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3_dev:6379/0'
DASHBOARD_SUMMARY_CACHE_TTL_SECONDS='30'
DASHBOARD_SUMMARY_SNAPSHOT_MAX_AGE_SECONDS='120'
DASHBOARD_SUMMARY_SNAPSHOT_TTL_SECONDS='86400'

# Host port mappings (compose)
COYOTE3_DEV_WEB_PORT='6801'
COYOTE3_DEV_API_PORT='6802'
COYOTE3_DEV_REDIS_PORT='6803'
COYOTE3_DEV_DOCS_PORT='6805'

# Optional container runtime limits
COYOTE3_DEV_CONTAINER_MEM_LIMIT='2g'
COYOTE3_DEV_CONTAINER_CPU_LIMIT='2.0'

# Build metadata (optional)
COYOTE3_VERSION='dev-local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'

# App behavior
FLASK_DEBUG='1'
DEVELOPMENT='1'
TESTING='0'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/dev/reports'

# LDAP authentication
LDAP_HOST='ldap://CHANGE_ME_LDAP_HOST'
LDAP_BASE_DN='CHANGE_ME_LDAP_BASE_DN'
LDAP_BINDDN='CHANGE_ME_LDAP_BINDDN'
LDAP_SECRET='CHANGE_ME_LDAP_SECRET'

# CORS (dev — set to your local origin, e.g. http://localhost:6801)
CORS_ORIGINS='http://localhost:6801'

# Center contact information
CONTACT_CLINICAL_EMAIL=''
CONTACT_RESEARCH_EMAIL=''
CONTACT_SAMPLES_EMAIL=''
CONTACT_PHONE_MAIN=''
CONTACT_PHONE_URGENT=''
CONTACT_ADDRESS=''

# Optional integrations
GENS_URI=''
IGV_URI=''

# SMTP mail delivery (org relay mode)
SMTP_HOST='mxis.skane.se'
SMTP_PORT='25'
SMTP_USERNAME=''
SMTP_PASSWORD=''
SMTP_USE_TLS='0'
SMTP_USE_SSL='0'
SMTP_FROM_EMAIL='noreply@coyote3.local'
SMTP_FROM_NAME='Coyote3'
WEB_APP_BASE_URL='http://localhost:6801/coyote3_dev'
HELP_CENTER_URL='http://localhost:6805/'
PASSWORD_TOKEN_TTL_SECONDS='3600'

# Request rate limiting
API_RATE_LIMIT_ENABLED='1'
API_RATE_LIMIT_REQUESTS_PER_MINUTE='600'
API_RATE_LIMIT_WINDOW_SECONDS='60'
WEB_RATE_LIMIT_ENABLED='1'
WEB_RATE_LIMIT_REQUESTS_PER_MINUTE='300'
WEB_RATE_LIMIT_WINDOW_SECONDS='60'
