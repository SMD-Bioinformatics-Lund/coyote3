# Development environment template.
# Copy to .coyote3_dev_env and replace all CHANGE_ME values.

# Core app secrets
SECRET_KEY='CHANGE_ME_DEV_SECRET_KEY'
COYOTE3_FERNET_KEY='CHANGE_ME_DEV_FERNET_KEY'
INTERNAL_API_TOKEN='CHANGE_ME_DEV_INTERNAL_TOKEN'
API_SESSION_SALT='CHANGE_ME_DEV_SESSION_SALT'

# Runtime identity
ENV_NAME='development'
COYOTE3_DB='coyote3_dev'
SESSION_COOKIE_NAME='coyote3_dev'
API_SESSION_COOKIE_NAME='coyote3_dev_api_session'
SCRIPT_NAME='/coyote3_dev'

# MongoDB (compose-managed dev Mongo)
MONGO_ROOT_USERNAME='coyote3_root'
MONGO_ROOT_PASSWORD='CHANGE_ME_DEV_ROOT_PASSWORD'
MONGO_APP_USER='coyote3_app'
MONGO_APP_PASSWORD='CHANGE_ME_DEV_APP_PASSWORD'
MONGO_URI='mongodb://coyote3_app:CHANGE_ME_DEV_APP_PASSWORD@coyote3_dev_mongo:27017/coyote3_dev'
COYOTE3_DEV_MONGO_PORT='37017'

# Redis
CACHE_REDIS_URL='redis://redis_coyote3_dev:6379/0'

# Host port mappings (compose)
COYOTE3_DEV_WEB_PORT='6817'
COYOTE3_DEV_API_PORT='6816'
COYOTE3_DEV_REDIS_PORT='5819'

# Build metadata (optional)
COYOTE3_VERSION='dev-local'
GIT_COMMIT='unknown'
BUILD_TIME='unknown'

# App behavior
FLASK_DEBUG='1'
DEVELOPMENT='1'
TESTING='0'
APP_DNS='1.1.1.1'
REPORTS_BASE_PATH='/data/coyote3/dev/reports'

# Optional integrations
GENS_URI=''
IGV_URI=''
LOCAL_AUTH_USER_IDENTIFIERS=''
