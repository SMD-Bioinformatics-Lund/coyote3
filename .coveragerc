[run]
branch = True
source =
    api
    coyote
omit =
    */tests/*
    */__pycache__/*
    */site-packages/*

[report]
skip_covered = False
show_missing = True
precision = 2
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError

[html]
directory = .coverage_html
