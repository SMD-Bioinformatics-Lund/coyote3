# Stage 1: MkDocs static site build
FROM python:3.12.0-slim-bullseye AS mkdocs_builder

WORKDIR /app

COPY requirements-docs.txt mkdocs.yml ./
RUN pip install --no-cache-dir -r requirements-docs.txt

COPY docs/ ./docs/
RUN mkdocs build --strict

# Stage 2: Dev runtime base
FROM python:3.12.0-slim-bullseye as coyote3_dev_runtime_base

LABEL base_image="python:3.12-slim"
LABEL about.home="https://github.com/Clinical-Genomics-Lund/coyote3"

# Set working directory
WORKDIR /app

# System environment variables (hardcoded, do not change often)
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV FLASK_APP=wsgi
ARG GIT_COMMIT="unknown"
ARG BUILD_TIME="unknown"
ENV GIT_COMMIT=${GIT_COMMIT}
ENV BUILD_TIME=${BUILD_TIME}

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxml2-dev libxslt1-dev zlib1g-dev libsasl2-dev libldap2-dev \
    build-essential libssl-dev libffi-dev libjpeg-dev libpq-dev \
    liblcms2-dev libblas-dev libatlas-base-dev libglib2.0-dev \
    libpango1.0-0 less vim && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install Python requirements
COPY requirements.txt .
RUN pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt

# Create logs directory
RUN mkdir ./logs
RUN mkdir ./redis_data

# Stage 3: Dev web runtime image
FROM coyote3_dev_runtime_base as coyote3_dev_web

EXPOSE 8000

COPY config/ ./config/
COPY config.py wsgi.py logging_setup.py cache_backend.py ./
COPY deploy/gunicorn/gunicorn.conf.py ./gunicorn.conf.py
COPY coyote/ ./coyote/
COPY shared/ ./shared/
COPY docs/ ./docs/
COPY CHANGELOG.md README.md LICENSE.txt ./
COPY --from=mkdocs_builder /app/site/ /app/site/

ENV SCRIPT_NAME="/coyote3_dev"
CMD gunicorn --timeout 240 -w 2 --threads 2 -e SCRIPT_NAME=${SCRIPT_NAME} --log-level DEBUG --bind 0.0.0.0:8000 wsgi:app

# Stage 4: Dev API runtime image
FROM coyote3_dev_runtime_base as coyote3_dev_api

EXPOSE 8001

COPY config/ ./config/
COPY config.py asgi.py run_api.py logging_setup.py cache_backend.py ./
COPY api/ ./api/
COPY shared/ ./shared/
COPY coyote/__version__.py ./coyote/__version__.py
COPY coyote/static/data/ ./coyote/static/data/
COPY scripts/ ./scripts/
COPY tests/ ./tests/

CMD python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8001 --workers 2

# Stage 5: Dev all-in-one image for test runner convenience
FROM coyote3_dev_runtime_base as coyote3_dev_all

COPY config/ ./config/
COPY config.py wsgi.py asgi.py run_api.py logging_setup.py cache_backend.py ./
COPY deploy/gunicorn/gunicorn.conf.py ./gunicorn.conf.py
COPY coyote/ ./coyote/
COPY api/ ./api/
COPY shared/ ./shared/
COPY docs/ ./docs/
COPY tests/ ./tests/
COPY scripts/ ./scripts/
COPY CHANGELOG.md README.md LICENSE.txt ./
COPY --from=mkdocs_builder /app/site/ /app/site/

ENV SCRIPT_NAME="/coyote3_dev"
CMD gunicorn --timeout 240 -w 2 --threads 2 -e SCRIPT_NAME=${SCRIPT_NAME} --log-level DEBUG --bind 0.0.0.0:8000 wsgi:app
